// Iterative fibonacci — tests while-loop + variable mutation
func fib_iter(n: number): number {
    if n <= 1 {
        return n;
    }
    let a = 0;
    let b = 1;
    let i = 2;
    while i <= n {
        let tmp = a + b;
        a = b;
        b = tmp;
        i = i + 1;
    }
    return b;
}
fib_iter(30);
