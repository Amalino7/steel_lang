impl number {
    func square(self): number {
        return self * self;
    }
}

func normal(b: number) {}
func other(a: number) {}
1.square(12);
number.square(12, 12);
normal(12);

{
    impl number {
        func add(self, a: Self): Self {
            return self + a;
        }
    }
}

normal = other;


